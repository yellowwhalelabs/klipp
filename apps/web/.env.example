# ─────────────────────────────────────────────────────────────────────────────
# KLIPP web app — environment variables.
# Copy to .env.local and fill in. NEXT_PUBLIC_* are exposed to the browser;
# everything else is server-only. Never commit real secrets (.env.local is
# gitignored; this template is not).
# ─────────────────────────────────────────────────────────────────────────────

# Privy — auth + embedded/smart wallets (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=

# Supabase — profiles + card-image storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Alchemy Gas Manager — gasless minting via ERC-4337 paymaster
#   1. In the Alchemy dashboard, create a Gas Manager policy that sponsors gas
#      ONLY for the KLIPPCard contract on Arbitrum Sepolia, with a per-user
#      daily spend cap (e.g. 0.01 ETH) to prevent abuse. Copy its policy id.
#   2. In the Privy dashboard (Smart Wallets), enable smart wallets with the
#      Alchemy implementation and set the bundler + Gas Manager paymaster URL
#      for Arbitrum Sepolia — that URL embeds ALCHEMY_API_KEY.
#   3. Set the policy id below so Alchemy sponsors the mint UserOperation.
NEXT_PUBLIC_ALCHEMY_GAS_POLICY_ID=
ALCHEMY_API_KEY=

# Deployed contracts — Arbitrum Sepolia (421614)
NEXT_PUBLIC_KLIPP_CARD_ADDRESS_SEPOLIA=0xcD238464cFE2901aF24e6d77585a19C2064Ca62A
NEXT_PUBLIC_KLIPP_PRO_CARD_ADDRESS_SEPOLIA=0x1a8F98b493d6c66d255536701c4Eb7E6553e288C
NEXT_PUBLIC_VESTING_ADDRESS=0xAce3a7b296E41B03bC77e91D2a0375B4Ea279B80

# Robinhood Chain testnet (46630)
NEXT_PUBLIC_ROBINHOOD_RPC=https://rpc.testnet.chain.robinhood.com
NEXT_PUBLIC_EQUITY_FACTORY_ADDRESS=
NEXT_PUBLIC_DEMO_CAP_TABLE_ADDRESS=
NEXT_PUBLIC_DEMO_EQUITY_TOKEN_ADDRESS=

# App
NEXT_PUBLIC_APP_URL=https://klipp-bay.vercel.app
