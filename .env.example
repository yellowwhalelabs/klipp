NEXT_PUBLIC_KLIPP_CARD_ADDRESS_SEPOLIA=0xcD238464cFE2901aF24e6d77585a19C2064Ca62A
NEXT_PUBLIC_KLIPP_PRO_CARD_ADDRESS_SEPOLIA=0x1a8F98b493d6c66d255536701c4Eb7E6553e288C

# --- Contract addresses: Robinhood Chain Testnet (chain 46630) ---
