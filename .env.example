# ============================================================
# KLIPP — Environment Variables Template
# Copy to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.
# ============================================================

# --- Privy (embedded wallet provider) ---
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Deployer wallet (dev only — NEVER expose) ---
DEPLOYER_PRIVATE_KEY=

# --- Chain RPC overrides ---
ROBINHOOD_TESTNET_RPC=https://robinhood-testnet.g.alchemy.com/v2/YOUR_KEY

# --- Optional: Alchemy Gas Manager (for ERC-4337 on Robinhood Chain) ---
ALCHEMY_GAS_POLICY_ID=

# --- Optional: Resend (email notifications) ---
RESEND_API_KEY=
