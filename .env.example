NEXT_PUBLIC_EQUITY_FACTORY_ADDRESS=0xcD238464cFE2901aF24e6d77585a19C2064Ca62A
NEXT_PUBLIC_DEMO_CAP_TABLE_ADDRESS=0x5e9bb5A815d2D6A81CAb1160f0A3b8BA35b4313D
